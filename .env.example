# PostgreSQL
POSTGRES_USER=imessage
POSTGRES_PASSWORD=imessage_dev
POSTGRES_DB=imessage_scheduler

# Backend API
DATABASE_URL=postgresql+asyncpg://imessage:imessage_dev@localhost:5432/imessage_scheduler
GATEWAY_URL=http://localhost:8001
SEND_RATE_PER_HOUR=1
QUEUE_POLL_INTERVAL_SECONDS=30
MAX_RETRY_ATTEMPTS=3
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_WS_URL=ws://localhost:8002

# Gateway
DRY_RUN=false
BACKEND_CALLBACK_URL=http://localhost:8002/api/webhooks/gateway-status
